-        delete status;
-        return;
-    }
-    if (!status || !status->IsOK()) {
-        return m_handler->HandleResponse(status, response);
-    }
-    auto stat_info = new XrdCl::StatInfo("nobody", 0, XrdCl::StatInfo::IsDir, 0);
-    auto obj = new XrdCl::AnyObject();
-    obj->Set(stat_info);
-    delete response;

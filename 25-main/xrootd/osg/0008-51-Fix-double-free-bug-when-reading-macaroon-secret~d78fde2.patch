From 1c54fb704b5d361cce9441458d72d92d483e86c7 Mon Sep 17 00:00:00 2001
From: Guilherme Amadio <amadio@cern.ch>
Date: Wed, 20 May 2026 15:27:43 +0200
Subject: [PATCH 8/8] [#51] Fix double free bug when reading macaroon secret

The call BIO_push(b64, bio) links the two BIOs, so calling
BIO_free_all() on both of them later causes a double free with
some versions of OpenSSL.

Fixes: f481c34b60509eb03e2673c55a733d902f71c1ca
Closes: #2797
---
 src/XrdMacaroons/XrdMacaroonsConfigure.cc | 9 +++------
 1 file changed, 3 insertions(+), 6 deletions(-)

diff --git a/src/XrdMacaroons/XrdMacaroonsConfigure.cc b/src/XrdMacaroons/XrdMacaroonsConfigure.cc
index f7eb1cd43..8581d3c17 100644
--- a/src/XrdMacaroons/XrdMacaroonsConfigure.cc
+++ b/src/XrdMacaroons/XrdMacaroonsConfigure.cc
@@ -194,15 +194,15 @@ bool Handler::xsecretkey(XrdOucStream &config_obj, XrdSysError *log, std::string
 
   BIO *b64 = BIO_new(BIO_f_base64());
   if (!b64) {
-    BIO_free_all(bio);
+    BIO_free(bio);
     log->Emsg("Config", "Failed to allocate base64 filter");
     return false;
   }
 
   BIO *bio_out = BIO_new(BIO_s_mem());
   if (!bio_out) {
-    BIO_free_all(b64);
-    BIO_free_all(bio);
+    BIO_free(b64);
+    BIO_free(bio);
     log->Emsg("Config", "Failed to allocate BIO output");
     return false;
   }
@@ -224,27 +224,24 @@ bool Handler::xsecretkey(XrdOucStream &config_obj, XrdSysError *log, std::string
   if (inlen < 0) {
     BIO_free_all(bio_out);
     BIO_free_all(b64);
-    BIO_free_all(bio);
     log->Emsg("Config", errno, "read secret key.");
     return false;
   }
 
   if (!BIO_flush(bio_out)) {
     BIO_free_all(bio_out);
     BIO_free_all(b64);
-    BIO_free_all(bio);
     log->Emsg("Config", errno, "flush secret key.");
     return false;
   }
 
   char *decoded;
   long data_len = BIO_get_mem_data(bio_out, &decoded);
 
   secret = std::string(decoded, data_len);
 
   BIO_free_all(bio_out);
   BIO_free_all(b64);
-  BIO_free_all(bio);
 
   if (secret.size() < 32) {
     log->Emsg("Config", "Secret key is too short; must be 32 bytes long.  Try running 'openssl rand -base64 -out", val, "64' to generate a new key");
-- 
